{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "大疆麦克风控制",
  "version": "1.1.0",
  "identifier": "org.djimic.control",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "大疆麦克风控制",
        "width": 1300,
        "height": 775,
        "minWidth": 760,
        "minHeight": 540,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "大疆麦克风控制",
    "targets": ["app", "dmg", "nsis", "deb", "rpm", "appimage"],
    "externalBin": ["bin/voice-comfort-engine"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/lib/udev/rules.d/60-dji-mic.rules": "../../packaging/60-dji-mic.rules"
        },
        "postInstallScript": "../../packaging/postinstall.sh",
        "postRemoveScript": "../../packaging/postremove.sh"
      },
      "rpm": {
        "files": {
          "/usr/lib/udev/rules.d/60-dji-mic.rules": "../../packaging/60-dji-mic.rules"
        },
        "postInstallScript": "../../packaging/postinstall.sh",
        "postRemoveScript": "../../packaging/postremove.sh"
      }
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
